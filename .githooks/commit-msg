#!/usr/bin/env sh
set -eu

msg_file="$1"
first_line="$(sed -n '1p' "$msg_file")"

# Allowed types: feat, chore, fix, doc, refactor
pattern='^(feat|chore|fix|doc|refactor)(\([[:alnum:]_.\/-]+\))?!?: .+'

if ! printf '%s' "$first_line" | grep -Eq "$pattern"; then
  echo "ERROR: Invalid commit message prefix."
  echo "Allowed formats: feat:, chore:, fix:, doc:, refactor:"
  echo "Example: feat: add user login"
  exit 1
fi
